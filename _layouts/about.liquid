---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle != blank %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article class="about-article">

    <!-- ── Scattered doodle ornaments: single wrapper div (not a flex item) ── -->
    <div class="about-scatter-layer" aria-hidden="true">

      <!-- top-left: star -->
      <svg class="about-scatter about-scatter--top-left" viewBox="0 0 44 44" width="44" height="44" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 4 L25 16 L37 12 L28 21 L38 27 L26 26 L24 38 L20 27 L8 30 L17 22 L8 15 L20 18 Z"
              fill="none" stroke="#333" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>

      <!-- top-right: three circles -->
      <svg class="about-scatter about-scatter--top-right" viewBox="0 0 52 26" width="52" height="26" xmlns="http://www.w3.org/2000/svg">
        <circle cx="10" cy="13" r="6"  fill="none" stroke="#333" stroke-width="1.8"/>
        <circle cx="26" cy="8"  r="4"  fill="#333" opacity="0.25"/>
        <circle cx="42" cy="16" r="7"  fill="none" stroke="#333" stroke-width="1.4" stroke-dasharray="3 2"/>
      </svg>

      <!-- mid-left: wavy line + bullseye -->
      <svg class="about-scatter about-scatter--mid-left" viewBox="0 0 50 34" width="50" height="34" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 10 C10 4, 18 16, 26 10 C34 4, 42 16, 48 10" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="26" cy="26" r="5"  fill="none" stroke="#333" stroke-width="1.5"/>
        <circle cx="26" cy="26" r="1.8" fill="#333" opacity="0.45"/>
      </svg>

      <!-- mid-right: compass cross -->
      <svg class="about-scatter about-scatter--mid-right" viewBox="0 0 44 44" width="44" height="44" xmlns="http://www.w3.org/2000/svg">
        <line x1="22" y1="5"  x2="22" y2="39" stroke="#333" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="5"  y1="22" x2="39" y2="22" stroke="#333" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="10" y1="10" x2="34" y2="34" stroke="#333" stroke-width="1"   stroke-linecap="round" opacity="0.35"/>
        <line x1="34" y1="10" x2="10" y2="34" stroke="#333" stroke-width="1"   stroke-linecap="round" opacity="0.35"/>
      </svg>

      <!-- bottom-left: Venn diagram circles -->
      <svg class="about-scatter about-scatter--bottom-left" viewBox="0 0 46 30" width="46" height="30" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="15" r="12" fill="none" stroke="#333" stroke-width="1.8"/>
        <circle cx="30" cy="15" r="12" fill="none" stroke="#333" stroke-width="1.8"/>
      </svg>

      <!-- bottom-right: lightning bolt + dots -->
      <svg class="about-scatter about-scatter--bottom-right" viewBox="0 0 48 44" width="48" height="44" xmlns="http://www.w3.org/2000/svg">
        <polyline points="28,4 16,20 30,20 14,40" fill="none" stroke="#333" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="40" cy="10" r="3"  fill="#333" opacity="0.2"/>
        <circle cx="8"  cy="34" r="2"  fill="#333" opacity="0.25"/>
      </svg>

    </div>
    <!-- ── end scatter ornaments ── -->

    <!-- Bio section -->
    <section class="about-section about-section--bio">
      {% if page.profile %}
        <div class="profile profile-about float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.15}}px, (min-width: 576px) 15vw, 95vw"{% endcapture %}
            {%
              include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
              cache_bust=true
            %}
          {% endif %}
          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}
          {% if page.social_in_profile %}
            <div class="about-social-icons about-social-icons--profile">
              {% social_links %}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div class="clearfix bio-content">{{ content }}</div>
      <!-- Waving stickman bottom-LEFT of bio card (position:absolute, no layout impact) -->
      <svg class="section-doodle doodle-bio-man" aria-hidden="true" viewBox="0 0 80 82" xmlns="http://www.w3.org/2000/svg">
        <!-- head -->
        <circle cx="36" cy="10" r="8.5" fill="none" stroke="#333" stroke-width="2.6"/>
        <circle cx="33" cy="8.5" r="1.5" fill="#333"/>
        <circle cx="39" cy="8.5" r="1.5" fill="#333"/>
        <path d="M33 14 Q36 17 39 14" fill="none" stroke="#333" stroke-width="1.6" stroke-linecap="round"/>
        <!-- body -->
        <line x1="36" y1="18.5" x2="36" y2="48" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- legs -->
        <line x1="36" y1="48" x2="24" y2="70" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <line x1="36" y1="48" x2="48" y2="70" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- left arm resting down -->
        <line x1="36" y1="30" x2="20" y2="42" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- right arm waving up -->
        <line x1="36" y1="30" x2="58" y2="14" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- speech bubble -->
        <rect x="54" y="0" rx="4" ry="4" width="26" height="14" fill="white" stroke="#333" stroke-width="1.4"/>
        <text x="58" y="11" font-size="8" fill="#333" font-family="sans-serif" font-weight="600">Hi!</text>
        <path d="M57 14 L54 20 L63 14" fill="white" stroke="#333" stroke-width="1.4" stroke-linejoin="round"/>
      </svg>
    </section>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
    <section class="about-section about-section--news">
      <h2 class="about-section-title">News</h2>
      {% include news.liquid limit=true %}
      <!-- Stickman sitting on edge reading a tiny newspaper, bottom-right -->
      <svg class="section-doodle doodle-news-man" aria-hidden="true" viewBox="0 0 68 75" xmlns="http://www.w3.org/2000/svg">
        <!-- sitting surface line -->
        <line x1="4" y1="36" x2="64" y2="36" stroke="#333" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.35"/>
        <!-- head -->
        <circle cx="32" cy="10" r="8" fill="none" stroke="#333" stroke-width="2.5"/>
        <circle cx="29" cy="8.5" r="1.3" fill="#333"/>
        <circle cx="35" cy="8.5" r="1.3" fill="#333"/>
        <path d="M29 14 Q32 16.5 35 14" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
        <!-- torso (sitting) -->
        <line x1="32" y1="18" x2="32" y2="36" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- legs dangling -->
        <line x1="32" y1="36" x2="23" y2="57" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="23" y1="57" x2="18" y2="68" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="32" y1="36" x2="41" y2="57" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="41" y1="57" x2="46" y2="68" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- left arm holding newspaper -->
        <line x1="32" y1="25" x2="16" y2="24" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- right arm holding other side of newspaper -->
        <line x1="32" y1="25" x2="52" y2="20" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- newspaper being held -->
        <rect x="14" y="16" rx="2" ry="2" width="40" height="26" fill="white" stroke="#333" stroke-width="1.8"/>
        <line x1="34" y1="16" x2="34" y2="42" stroke="#333" stroke-width="1" opacity="0.4"/>
        <line x1="17" y1="22" x2="31" y2="22" stroke="#333" stroke-width="1" opacity="0.4"/>
        <line x1="17" y1="26" x2="30" y2="26" stroke="#333" stroke-width="1" opacity="0.3"/>
        <line x1="17" y1="30" x2="29" y2="30" stroke="#333" stroke-width="1" opacity="0.3"/>
        <line x1="37" y1="22" x2="51" y2="22" stroke="#333" stroke-width="1" opacity="0.4"/>
        <line x1="37" y1="26" x2="50" y2="26" stroke="#333" stroke-width="1" opacity="0.3"/>
      </svg>
    </section>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
    <section class="about-section about-section--publications">
      <h2 class="about-section-title">Selected Publications</h2>
      <p class="post-description">* indicates equal contribution.</p>
      {% include selected_papers.liquid %}
      <!-- Graduation stickman celebrating at bottom-right (position:absolute, no layout impact) -->
      <svg class="section-doodle doodle-grad-man" aria-hidden="true" viewBox="0 0 78 92" xmlns="http://www.w3.org/2000/svg">
        <!-- graduation cap board -->
        <line x1="10" y1="9" x2="52" y2="9" stroke="#333" stroke-width="3" stroke-linecap="round"/>
        <!-- cap body -->
        <rect x="24" y="2" rx="1" ry="1" width="14" height="8" fill="#333"/>
        <!-- tassel -->
        <line x1="51" y1="9" x2="56" y2="21" stroke="#333" stroke-width="1.6" stroke-linecap="round"/>
        <circle cx="56" cy="23" r="2.8" fill="#333"/>
        <!-- head -->
        <circle cx="31" cy="20" r="9" fill="none" stroke="#333" stroke-width="2.6"/>
        <!-- happy eyes -->
        <path d="M27 18 Q29 20 31 18" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M31 18 Q33 20 35 18" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
        <!-- big smile -->
        <path d="M26 23 Q31 28 36 23" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round"/>
        <!-- body -->
        <line x1="31" y1="29" x2="31" y2="60" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- legs apart (triumphant) -->
        <line x1="31" y1="60" x2="18" y2="82" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <line x1="31" y1="60" x2="44" y2="82" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- both arms raised in V -->
        <line x1="31" y1="42" x2="8"  y2="26" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <line x1="31" y1="42" x2="56" y2="24" stroke="#333" stroke-width="2.6" stroke-linecap="round"/>
        <!-- diploma scroll in right hand -->
        <rect x="54" y="16" rx="3" ry="3" width="16" height="11" fill="white" stroke="#333" stroke-width="1.8"/>
        <line x1="57" y1="21" x2="67" y2="21" stroke="#333" stroke-width="1" opacity="0.6"/>
        <line x1="57" y1="24" x2="65" y2="24" stroke="#333" stroke-width="1" opacity="0.5"/>
      </svg>
    </section>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        {% if site.contact_note != blank %}
          <div class="contact-note">{{ site.contact_note }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
