---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle != blank %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article class="about-article">
    <!-- Decorative doodle stick figures -->
    <div class="doodle-figures" aria-hidden="true">

      <!-- Waving guy sitting on top-right of Bio card -->
      <svg class="doodle doodle--sitter" viewBox="0 0 100 80" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="12" r="9" fill="none" stroke="#333" stroke-width="2.8"/>
        <circle cx="46" cy="10" r="1.8" fill="#333"/>
        <circle cx="54" cy="10" r="1.8" fill="#333"/>
        <path d="M46 16 Q50 20 54 16" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="50" y1="21" x2="50" y2="46" stroke="#333" stroke-width="2.8" stroke-linecap="round"/>
        <line x1="50" y1="46" x2="36" y2="64" stroke="#333" stroke-width="2.8" stroke-linecap="round"/>
        <line x1="50" y1="46" x2="64" y2="64" stroke="#333" stroke-width="2.8" stroke-linecap="round"/>
        <line x1="50" y1="30" x2="30" y2="22" stroke="#333" stroke-width="2.8" stroke-linecap="round"/>
        <path d="M70 8 L68 2 M70 8 L76 6" stroke="#333" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <line x1="50" y1="30" x2="70" y2="8" stroke="#333" stroke-width="2.8" stroke-linecap="round"/>
        <!-- speech bubble -->
        <rect x="72" y="0" rx="4" ry="4" width="28" height="16" fill="none" stroke="#333" stroke-width="1.5"/>
        <text x="78" y="12" font-size="9" fill="#333" font-family="monospace">Hi!</text>
        <polygon points="74,16 78,16 72,22" fill="none" stroke="#333" stroke-width="1.5"/>
      </svg>

      <!-- Guy climbing / hanging on the left side between sections -->
      <svg class="doodle doodle--climber" viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg">
        <line x1="30" y1="0" x2="30" y2="25" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-dasharray="3 3"/>
        <circle cx="30" cy="34" r="8" fill="none" stroke="#333" stroke-width="2.5"/>
        <circle cx="27" cy="32" r="1.5" fill="#333"/>
        <circle cx="33" cy="32" r="1.5" fill="#333"/>
        <path d="M27 37 Q30 39 33 37" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="30" y1="42" x2="30" y2="72" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="30" y1="52" x2="14" y2="28" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="30" y1="52" x2="46" y2="28" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="30" y1="72" x2="20" y2="95" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="30" y1="72" x2="40" y2="95" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
      </svg>

      <!-- Two figures pulling a rope below publications -->
      <svg class="doodle doodle--pullers" viewBox="0 0 260 80" xmlns="http://www.w3.org/2000/svg">
        <!-- rope -->
        <path d="M 40 32 C 80 28, 100 36, 130 32 C 160 28, 180 36, 220 32" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round"/>
        <!-- left figure (leaning back, pulling) -->
        <g>
          <circle cx="36" cy="10" r="7.5" fill="none" stroke="#333" stroke-width="2.5"/>
          <circle cx="33" cy="8.5" r="1.3" fill="#333"/>
          <circle cx="39" cy="8.5" r="1.3" fill="#333"/>
          <path d="M33 13 Q36 15.5 39 13" fill="none" stroke="#333" stroke-width="1.3"/>
          <line x1="36" y1="17.5" x2="32" y2="48" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="32" y1="48" x2="20" y2="72" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="32" y1="48" x2="42" y2="72" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="32" y1="30" x2="18" y2="36" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="32" y1="30" x2="42" y2="32" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        </g>
        <!-- right figure (leaning back, pulling other way) -->
        <g>
          <circle cx="224" cy="10" r="7.5" fill="none" stroke="#333" stroke-width="2.5"/>
          <circle cx="221" cy="8.5" r="1.3" fill="#333"/>
          <circle cx="227" cy="8.5" r="1.3" fill="#333"/>
          <path d="M221 13 Q224 15.5 227 13" fill="none" stroke="#333" stroke-width="1.3"/>
          <line x1="224" y1="17.5" x2="228" y2="48" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="228" y1="48" x2="218" y2="72" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="228" y1="48" x2="240" y2="72" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="228" y1="30" x2="218" y2="32" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="228" y1="30" x2="242" y2="36" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        </g>
        <!-- little flag in the middle -->
        <line x1="130" y1="32" x2="130" y2="10" stroke="#333" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M130 10 L144 16 L130 22" fill="#333" opacity="0.15" stroke="#333" stroke-width="1"/>
      </svg>

      <!-- Reading figure sitting on right side -->
      <svg class="doodle doodle--reader" viewBox="0 0 80 90" xmlns="http://www.w3.org/2000/svg">
        <circle cx="40" cy="12" r="8" fill="none" stroke="#333" stroke-width="2.5"/>
        <circle cx="37" cy="10" r="1.3" fill="#333"/>
        <circle cx="43" cy="10" r="1.3" fill="#333"/>
        <path d="M37 15 Q40 17 43 15" fill="none" stroke="#333" stroke-width="1.3"/>
        <line x1="40" y1="20" x2="40" y2="48" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="40" y1="48" x2="30" y2="70" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="40" y1="48" x2="50" y2="56" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="56" x2="50" y2="70" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- arms holding book -->
        <line x1="40" y1="30" x2="28" y2="38" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="40" y1="30" x2="52" y2="38" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
        <!-- book -->
        <rect x="26" y="36" rx="1" ry="1" width="28" height="18" fill="none" stroke="#333" stroke-width="2"/>
        <line x1="40" y1="36" x2="40" y2="54" stroke="#333" stroke-width="1.5"/>
        <line x1="30" y1="41" x2="38" y2="41" stroke="#333" stroke-width="1" opacity="0.5"/>
        <line x1="30" y1="44" x2="37" y2="44" stroke="#333" stroke-width="1" opacity="0.5"/>
        <line x1="42" y1="41" x2="50" y2="41" stroke="#333" stroke-width="1" opacity="0.5"/>
        <line x1="42" y1="44" x2="49" y2="44" stroke="#333" stroke-width="1" opacity="0.5"/>
      </svg>

      <!-- Scattered doodle decorations -->
      <svg class="doodle doodle--scatter-top" viewBox="0 0 400 50" xmlns="http://www.w3.org/2000/svg">
        <circle cx="45" cy="20" r="4" fill="none" stroke="#333" stroke-width="1.5" opacity="0.25"/>
        <circle cx="120" cy="35" r="3" fill="#333" opacity="0.08"/>
        <path d="M200 8 L203 16 L211 16 L205 21 L207 29 L200 24 L193 29 L195 21 L189 16 L197 16 Z" fill="none" stroke="#333" stroke-width="1.3" opacity="0.2"/>
        <circle cx="290" cy="25" r="5" fill="none" stroke="#333" stroke-width="1" stroke-dasharray="2 3" opacity="0.2"/>
        <path d="M350 15 Q355 5 360 15 Q365 25 370 15" fill="none" stroke="#333" stroke-width="1.5" opacity="0.2"/>
      </svg>

      <svg class="doodle doodle--scatter-bottom" viewBox="0 0 400 50" xmlns="http://www.w3.org/2000/svg">
        <path d="M30 30 L33 22 L36 30" fill="none" stroke="#333" stroke-width="1.5" opacity="0.2"/>
        <circle cx="100" cy="18" r="3" fill="none" stroke="#333" stroke-width="1.5" opacity="0.15"/>
        <path d="M170 20 C175 10, 185 10, 190 20 C195 30, 205 30, 210 20" fill="none" stroke="#333" stroke-width="1.3" opacity="0.15"/>
        <circle cx="270" cy="28" r="2.5" fill="#333" opacity="0.06"/>
        <path d="M320 12 L324 12 L322 8 Z" fill="#333" opacity="0.12"/>
        <path d="M360 35 Q365 25 370 35" fill="none" stroke="#333" stroke-width="1.2" opacity="0.15"/>
      </svg>
    </div>

    <!-- Bio section -->
    <section class="about-section about-section--bio">
      {% if page.profile %}
        <div class="profile profile-about float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.15}}px, (min-width: 576px) 15vw, 95vw"{% endcapture %}
            {%
              include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
              cache_bust=true
            %}
          {% endif %}
          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}
          {% if page.social_in_profile %}
            <div class="about-social-icons about-social-icons--profile">
              {% social_links %}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div class="clearfix bio-content">{{ content }}</div>
    </section>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
    <section class="about-section about-section--news">
      <h2 class="about-section-title">News</h2>
      {% include news.liquid limit=true %}
    </section>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
    <section class="about-section about-section--publications">
      <h2 class="about-section-title">Selected Publications</h2>
      <p class="post-description">* indicates equal contribution.</p>
      {% include selected_papers.liquid %}
    </section>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        {% if site.contact_note != blank %}
          <div class="contact-note">{{ site.contact_note }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
