---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle != blank %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article class="about-article">
    <!-- Bio section -->
    <section class="about-section about-section--bio">
      {% if page.profile %}
        <div class="profile profile-about float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.15}}px, (min-width: 576px) 15vw, 95vw"{% endcapture %}
            {%
              include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
              cache_bust=true
            %}
          {% endif %}
          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}
          {% if page.social_in_profile %}
            <div class="about-social-icons about-social-icons--profile">
              {% social_links %}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div class="clearfix bio-content">{{ content }}</div>
      <!-- Waving stickman at bottom-right of bio card -->
      <svg class="section-doodle doodle-bio-man" aria-hidden="true" viewBox="0 0 110 90" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="12" r="9" fill="none" stroke="#444" stroke-width="2.5"/>
        <circle cx="46" cy="10" r="1.6" fill="#444"/>
        <circle cx="54" cy="10" r="1.6" fill="#444"/>
        <path d="M46 16 Q50 20 54 16" fill="none" stroke="#444" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="50" y1="21" x2="50" y2="48" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="48" x2="37" y2="68" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="48" x2="63" y2="68" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="30" x2="32" y2="23" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="30" x2="68" y2="12" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <rect x="72" y="2" rx="5" ry="5" width="35" height="18" fill="white" stroke="#444" stroke-width="1.5"/>
        <text x="78" y="15" font-size="9" fill="#444" font-family="sans-serif" font-weight="bold">Hi!</text>
        <path d="M75 20 L72 26 L82 20" fill="white" stroke="#444" stroke-width="1.5" stroke-linejoin="round"/>
      </svg>
    </section>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
    <section class="about-section about-section--news">
      <h2 class="about-section-title">News</h2>
      {% include news.liquid limit=true %}
      <!-- Stickman sitting on top-right of news card -->
      <svg class="section-doodle doodle-news-man" aria-hidden="true" viewBox="0 0 70 80" xmlns="http://www.w3.org/2000/svg">
        <circle cx="35" cy="10" r="8" fill="none" stroke="#444" stroke-width="2.5"/>
        <circle cx="32" cy="8.5" r="1.4" fill="#444"/>
        <circle cx="38" cy="8.5" r="1.4" fill="#444"/>
        <path d="M32 14 Q35 17 38 14" fill="none" stroke="#444" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="35" y1="18" x2="35" y2="44" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="35" y1="44" x2="44" y2="64" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="35" y1="44" x2="26" y2="64" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="35" y1="28" x2="20" y2="36" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="35" y1="28" x2="52" y2="22" stroke="#444" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M48 20 L55 14 L55 20" fill="none" stroke="#444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </section>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
    <section class="about-section about-section--publications">
      <h2 class="about-section-title">Selected Publications</h2>
      <p class="post-description">* indicates equal contribution.</p>
      {% include selected_papers.liquid %}
      <!-- Two stickmen pulling rope at bottom of publications card -->
      <div class="doodle-pullers-wrap" aria-hidden="true">
        <svg class="doodle-pullers-svg" viewBox="0 0 340 72" xmlns="http://www.w3.org/2000/svg">
          <!-- left figure leaning back -->
          <circle cx="42" cy="10" r="8" fill="none" stroke="#444" stroke-width="2.4"/>
          <circle cx="39" cy="8.5" r="1.4" fill="#444"/>
          <circle cx="45" cy="8.5" r="1.4" fill="#444"/>
          <path d="M39 14 Q42 17 45 14" fill="none" stroke="#444" stroke-width="1.4"/>
          <line x1="42" y1="18" x2="38" y2="46" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="38" y1="46" x2="28" y2="68" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="38" y1="46" x2="48" y2="68" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="38" y1="30" x2="22" y2="36" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="38" y1="30" x2="56" y2="30" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <!-- right figure leaning back (mirrored) -->
          <circle cx="298" cy="10" r="8" fill="none" stroke="#444" stroke-width="2.4"/>
          <circle cx="295" cy="8.5" r="1.4" fill="#444"/>
          <circle cx="301" cy="8.5" r="1.4" fill="#444"/>
          <path d="M295 14 Q298 17 301 14" fill="none" stroke="#444" stroke-width="1.4"/>
          <line x1="298" y1="18" x2="302" y2="46" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="302" y1="46" x2="292" y2="68" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="302" y1="46" x2="312" y2="68" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="302" y1="30" x2="318" y2="36" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <line x1="302" y1="30" x2="284" y2="30" stroke="#444" stroke-width="2.4" stroke-linecap="round"/>
          <!-- wavy rope between them -->
          <path d="M56 30 C90 24, 110 36, 140 30 C170 24, 200 36, 230 30 C260 24, 275 36, 284 30" fill="none" stroke="#444" stroke-width="2" stroke-linecap="round"/>
          <!-- decorative dots -->
          <circle cx="170" cy="5" r="3" fill="#444" opacity="0.15"/>
          <circle cx="130" cy="65" r="2.5" fill="#444" opacity="0.12"/>
          <circle cx="210" cy="62" r="2" fill="#444" opacity="0.1"/>
        </svg>
      </div>
    </section>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        {% if site.contact_note != blank %}
          <div class="contact-note">{{ site.contact_note }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
